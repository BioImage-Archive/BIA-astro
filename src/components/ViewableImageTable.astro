---
import ImageRow from "./ImageTableRow.astro"
import { getImageFromAPI, asyncPool } from "./SharedJSFunctions";

const { study, images, imagePageRoot } = Astro.props;
const imagesWithMetadata = await asyncPool(
  100,                                // max concurrent API calls
  images,
  async (image) => {
    const metadata = await getImageFromAPI(image.uuid);
    return { image, metadata };
  }
);
---

<section class="vf-intro | embl-grid embl-grid--has-centered-content | section-spacing">
    <div class="vf-section-header">
      <h2 class="vf-section-header__heading" id="viewable_images">
        Viewable Images
      </h2>
    </div>
    <div>
      <table id="viewable_images_table" class="display">
        <thead>
          <tr>
            <th>Preview</th>
            <th>UUID</th>
            <th>Dataset</th>
            <th>Download Size (bytes)</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {
            imagesWithMetadata.map(({ image, metadata }) => (
            <ImageRow
              image={image}
              metadata={metadata}
              datasetTitle={study.dataset.find((d) => d.uuid === image.submission_dataset_uuid).title}
              imagePageRoot={imagePageRoot}
            />
          ))}
        </tbody>
      </table>
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
              $("#viewable_images_table").DataTable({
                scrollX: true,
                columnDefs: [{ type: "natural", targets: 0 }],
              });
            });

    </script>
</section>